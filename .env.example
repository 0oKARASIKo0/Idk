# Qwen AI Agent Configuration
# Copy this file to .env and fill in your values

# LLM Configuration (local Ollama by default)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5

# For remote API (optional)
USE_REMOTE_API=false
REMOTE_API_URL=
REMOTE_API_KEY=

# Agent Settings
THINKING_INTERVAL=2.0
MAX_CONTEXT_LENGTH=4096
MEMORY_SIZE=50

# Voice Settings
VOICE_LANGUAGE=ru-RU
VOICE_SAMPLE_RATE=16000
VOICE_ENERGY_THRESHOLD=300

# Camera Settings
CAMERA_INDEX=0
CAMERA_FPS=30
CAMERA_FRAME_WIDTH=640
CAMERA_FRAME_HEIGHT=480

# Mouse and Keyboard
MOUSE_SPEED=0.5
KEYBOARD_TYPING_SPEED=0.05

# Behavior
ACTION_COOLDOWN=0.5
STRATEGY_CHANGE_THRESHOLD=0.7
